# CleanFloor 모션 파라미터 (SpiralPlanner용)
# 값이 0.0이면 Isaac Sim spiral_planner.py의 기본값 사용
float64 tank_diameter     # 수조 직경 (m), 0.0=default
float64 tank_margin       # 벽면 여유 (m), 0.0=default
float64 robot_footprint   # 로봇 폭 (m), 0.0=default
float64 linear_speed      # 선속도 (m/s), 0.0=default
float64 omega_max         # 최대 각속도 (rad/s), 0.0=default
